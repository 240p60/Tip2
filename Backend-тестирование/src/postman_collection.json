              "});",
              "",
              "pm.test(\"Response body is empty object\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(Object.keys(json).length).to.eql(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
