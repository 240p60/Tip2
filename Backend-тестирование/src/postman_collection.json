          "raw": "{\n  \"id\": {{post_id}},\n  \"title\": \"Updated title\",\n  \"body\": \"Body has been fully replaced via PUT.\",\n  \"userId\": {{user_id}}\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["posts", "{{post_id}}"]
        }
